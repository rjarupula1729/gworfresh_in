{
  "name": "growfresh",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "scripts": {
    "db:build": "node scripts/build-db-bundle.js",
    "db:watch": "node scripts/db-watch-bundle.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build -p android --profile preview",
    "build:internal": "eas build -p android --profile internal",
    "build:production": "eas build -p android --profile production",
    "build:lan": "eas build -p android --profile lan",
    "submit:internal": "eas submit -p android --profile internal --latest",
    "submit:production": "eas submit -p android --profile production --latest"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "axios": "^1.6.0",
    "expo": "~51.0.0",
    "expo-build-properties": "^0.12.5",
    "expo-constants": "~16.0.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-location": "~17.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-updates": "~0.25.0",
    "react": "18.2.0",
    "react-native": "^0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
