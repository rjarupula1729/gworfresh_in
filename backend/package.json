{
  "name": "growfresh-backend",
  "version": "1.0.0",
  "description": "GrowFresh Agriculture E-commerce Backend (Postgres)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "knex migrate:latest --knexfile ./knexfile.js",
    "db:rollback": "knex migrate:rollback --knexfile ./knexfile.js",
    "db:seed": "knex seed:run --knexfile ./knexfile.js",
    "db:reset": "knex migrate:rollback --all --knexfile ./knexfile.js && knex migrate:latest --knexfile ./knexfile.js && knex seed:run --knexfile ./knexfile.js"
  },
  "keywords": [
    "agriculture",
    "ecommerce",
    "growfresh",
    "postgres"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.3.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
  "engines": {
    "node": "18.x",
    "npm": "9.x"
  }
}
