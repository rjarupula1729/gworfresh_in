# ─── GrowFresh backend environment ────────────────────────────
# Copy this file to `.env` and adjust values for your machine.

NODE_ENV=development
PORT=5000

# ─── Postgres ─────────────────────────────────────────────────
# Option A – single connection URL (preferred for cloud / prod)
# DATABASE_URL=postgres://user:password@host:5432/growfresh

# Option B – discrete vars (used when DATABASE_URL is not set)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=growfresh

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRE=30d

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins; "*" allows all (dev only).
# In production set this to your mobile app's web origin or admin URL.
CORS_ORIGIN=*
